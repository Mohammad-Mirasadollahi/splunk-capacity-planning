# scpcalc environment configuration
# Copy to .env and adjust. Existing OS env vars are never overwritten by this file.
#
# Priority for listen address:
#   1) CLI:  scpcalc serve --addr HOST:PORT
#            scpcalc serve --host HOST --port PORT
#   2) Environment variables (SCPCALC_*)
#   3) This .env file
#   4) Defaults: host=0.0.0.0 port=12345

# Full listen address (optional). If set, overrides HOST+PORT.
# SCPCALC_ADDR=0.0.0.0:12345

SCPCALC_HOST=0.0.0.0
SCPCALC_PORT=12345

# Optional: path to another env file
# SCPCALC_ENV_FILE=/etc/scpcalc.env
